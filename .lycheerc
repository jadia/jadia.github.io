# Lychee configuration
# https://github.com/lycheeverse/lychee#configuration
# Lychee configuration file
# See https://github.com/lycheeverse/lychee#configuration-file

--root-dir _site
--no-progress
--max-concurrency 10
--scheme http
--scheme https

# Don't check these links
--exclude-mail

# Exclude internal file lookups to eliminate noise from clean URLs
--exclude "file://.*"

# Ignore specific URL patterns
--exclude ^http://127\.0\.0\.1
--exclude ^http://localhost
--exclude ^https://jadia\.dev
--exclude ^#$
# Exclude domains that aggressively block crawlers with 403/401
--exclude "dzone.com"
--exclude "backblaze.com"
--exclude "community.cloudflare.com"
--exclude "raspberrypi.com"

# Exclude other known false positives or irrelevant links
--exclude "linkedin.com"
--exclude "twitter.com"
--exclude "facebook.com"
--exclude "fonts.gstatic.com"
--exclude "disqus.com"
--exclude "disquscdn.com"
--exclude "google-analytics.com"
--exclude .*medium\.com.*
--exclude .*cloudflare\.com.*
--exclude .*raspberrypi\.(org|com).*

# Retry logic for transient internet issues
--retry-wait-time 5
# Accept 403 because many technical blogs/docs block crawlers but links are still valid
--accept 200,201,429,403
--max-retries 2

# Output formatting
--output lychee-report.md
