---
layout: null
permalink: /search.json
---
[
  {% assign search_entries = site.posts | sort: "date" | reverse %}
  {% for entry in search_entries %}
    {
      "title": {{ entry.title | jsonify }},
      "url": {{ entry.url | relative_url | jsonify }},
      "section": "posts",
      "date": {{ entry.date | date: "%Y-%m-%d" | jsonify }},
      "summary": {{ entry.summary | default: entry.description | default: entry.excerpt | strip_html | strip_newlines | jsonify }},
      "tags": {{ entry.tags | jsonify }},
      "content": {{ entry.content | strip_html | strip_newlines | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
